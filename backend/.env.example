# Flask Environment Configuration
FLASK_ENV=development

# Database URL
# For local development with SQLite (default):
DATABASE_URL=sqlite:///fundraising.db

# For local development with PostgreSQL:
# DATABASE_URL=postgresql://username:password@localhost:5432/fundraising

# For production (Render will set this automatically):
# DATABASE_URL=postgresql://user:password@host:port/database

# Port (Render will set this automatically in production)
PORT=5000

