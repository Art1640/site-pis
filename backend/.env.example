# Backend Environment Variables Template
# Copy this file to .env and customize for your local development

# ============================================
# LOCAL DEVELOPMENT SETTINGS (Default)
# ============================================

# Flask environment mode
FLASK_ENV=development

# Database URL
# Leave commented to use SQLite (default: backend/instance/fundraising.db)
# DATABASE_URL=sqlite:///fundraising.db

# For local PostgreSQL development (optional):
# DATABASE_URL=postgresql://username:password@localhost:5432/fundraising

# Server port
PORT=5000

# Admin password for authentication
ADMIN_PASSWORD=tamère

# ============================================
# PRODUCTION SETTINGS (Reference Only)
# ============================================
# These values are set automatically by Render
# See: render.yaml
#
# DATABASE_URL=postgresql://user:password@host:port/database (auto-injected)
# PORT=10000 (auto-injected)
# FLASK_ENV=production
# ADMIN_PASSWORD=your_secure_password (set manually in Render dashboard)

# ============================================
# NOTES
# ============================================
# - This file (.env.example) is tracked in git as a template
# - Your actual .env file is NOT tracked (see .gitignore)
# - Production values are auto-injected by Render
# - SQLite is used by default for local development
# - PostgreSQL is used in production (Render)

