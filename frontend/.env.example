# Frontend Environment Variables Template
# Copy this file to .env and customize for your local development

# ============================================
# LOCAL DEVELOPMENT SETTINGS (Default)
# ============================================

# Use backend API (true) or localStorage mode (false)
VITE_USE_BACKEND=true

# Backend API URL - Points to local Flask server
VITE_API_URL=http://localhost:5000

# ============================================
# PRODUCTION SETTINGS (Reference Only)
# ============================================
# These values are injected by GitHub Actions during deployment
# See: .github/workflows/deploy.yml
#
# VITE_USE_BACKEND=true
# VITE_API_URL=https://site-pis.onrender.com

# ============================================
# NOTES
# ============================================
# - This file (.env.example) is tracked in git as a template
# - Your actual .env file is NOT tracked (see .gitignore)
# - Production values are set in GitHub Actions workflow
# - Never commit sensitive data or production URLs to .env
