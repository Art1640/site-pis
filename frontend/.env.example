# Environment configuration for different hosting scenarios

# For custom domains (like moulah-pi.fr), leave empty or set to "/"
# VITE_BASE_PATH=/

# For GitHub Pages subdirectory deployment, set to your repo name
# VITE_BASE_PATH=/site-pis/

# Force GitHub Pages mode (optional)
# VITE_GITHUB_PAGES=true

# Backend API Configuration
# For local development:
VITE_API_URL=http://localhost:5000

# For production (replace with your Render backend URL):
# VITE_API_URL=https://your-app-name.onrender.com

# Use backend API (true) or localStorage (false)
VITE_USE_BACKEND=true
